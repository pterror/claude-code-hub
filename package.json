{
  "name": "claude-code-hub",
  "version": "0.1.0",
  "description": "Simple orchestration hub for Claude Code agents. Server + reference UI.",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/server.ts",
    "start": "bun run src/server.ts",
    "typecheck": "tsgo --noEmit",
    "typecheck:ui": "cd ui && tsgo -p jsconfig.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "web-push": "^3.6.7",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260120.1",
    "typescript": "^5.9.3"
  }
}
